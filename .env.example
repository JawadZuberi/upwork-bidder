# ─── Required ───────────────────────────────────────────
# Anthropic API key — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# ─── Vercel KV (auto-filled when you add a KV database in Vercel dashboard) ─
KV_URL=
KV_REST_API_URL=
KV_REST_API_TOKEN=
KV_REST_API_READ_ONLY_TOKEN=

# ─── Cron security (set any random string, e.g. openssl rand -hex 32) ───────
CRON_SECRET=your-secret-here
